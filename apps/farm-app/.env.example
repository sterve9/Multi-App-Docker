# ─── Base de données ──────────────────────────────────────
POSTGRES_DB=farm_db
POSTGRES_USER=farm_user
POSTGRES_PASSWORD=CHANGE_MOI_DB_PASSWORD

# ─── Auth Backend ──────────────────────────────────────────
# Identifiant de connexion à l'app
ADMIN_USERNAME=patron

# Hash bcrypt du mot de passe — générer avec : python generate_hash.py
ADMIN_PASSWORD_HASH=$2b$12$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Clé secrète JWT — générer avec : openssl rand -hex 32
SECRET_KEY=CHANGE_MOI_SECRET_KEY_32_CHARS_MIN

# ─── URLs ──────────────────────────────────────────────────
FRONTEND_URL=https://ferme.sterveshop.cloud
NEXT_PUBLIC_API_URL=https://api.ferme.sterveshop.cloud

# ─── Intelligence Artificielle ─────────────────────────
# Clé API Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX

# ─── N8N Webhooks ──────────────────────────────────────────
# URL du webhook N8N pour les alertes de stock bas
N8N_WEBHOOK_STOCK_ALERTE=https://automation.sterveshop.cloud/webhook/stock-alerte
